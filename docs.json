{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "HelixDB Docs",
  "styling": {
    "codeblocks": {
      "languages": {
        "custom": ["languages/helixql.json"]
      }
    }
  },
  "colors": {
    "primary": "#F26419",
    "light": "#FF8548",
    "dark": "#F26419"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#FDFBF0",
      "dark": "#1E1715"
    }
  },
  "fonts": {
  },
  "head": [
    {
      "tag": "link",
      "attributes": {
        "rel": "preconnect",
        "href": "https://fonts.googleapis.com"
      }
    },
    {
      "tag": "link",
      "attributes": {
        "rel": "preconnect",
        "href": "https://fonts.gstatic.com",
        "crossorigin": ""
      }
    },
    {
      "tag": "link",
      "attributes": {
        "rel": "stylesheet",
        "href": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=block"
      }
    },
    {
      "tag": "link",
      "attributes": {
        "rel": "alternate",
        "type": "text/markdown",
        "href": "/llms-full.txt",
        "title": "Full markdown corpus for AI agents"
      }
    },
    {
      "tag": "link",
      "attributes": {
        "rel": "alternate",
        "type": "text/markdown",
        "href": "/llms.txt",
        "title": "Documentation index for AI agents"
      }
    },
    {
      "tag": "style",
      "children": ".llms-pointer{position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden}"
    },
    {
      "tag": "script",
      "children": "document.addEventListener('DOMContentLoaded',function(){if(document.querySelector('.llms-pointer'))return;var p=document.createElement('blockquote');p.className='llms-pointer';p.innerHTML='For the complete documentation index optimized for AI agents, see <a href=\"/llms.txt\">llms.txt</a>.';document.body.insertBefore(p,document.body.firstChild);});"
    }
  ],
  "favicon": "/favicon.svg",
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      {
        "title": "Open in T3 Chat",
        "description": "Ask questions about this page",
        "icon": "https://t3.chat/favicon.ico",
        "href": {
          "base": "https://t3.chat/new",
          "query": [
            {
              "key": "q",
              "value": "Read from https://docs.helix-db.com/$path so I can ask questions about it."
            }
          ]
        }
      },
      "mcp"
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "icon": "desktop",
          "href": "https://helix-db.com/login"
        },
        {
          "anchor": "Status",
          "icon": "signal",
          "href": "https://status.helix-db.com"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/HelixDB/helix-db"
        },
        {
          "anchor": "HelixDB DSL Docs",
          "icon": "code",
          "href": "https://docs.rs/helix-enterprise-ql/latest/helix_dsl/"
        }
      ]
    },
    "tabs": [
      {
        "tab": "HelixDB Cloud",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "enterprise/introduction",
              "enterprise/local-development",
              "enterprise/working-with-enterprise",
              "enterprise/architecture",
              "enterprise/guarantees",
              "enterprise/security",
              "enterprise/tradeoffs",
              "enterprise/limits",
              "enterprise/roadmap",
              "enterprise/release-notes"
            ]
          },

          {
            "group": "Concepts & Examples",
            "pages": [
              "enterprise/data-model",
              "enterprise/querying",
              "enterprise/indexing/secondary",
              "enterprise/indexing/vector",
              "enterprise/indexing/text",
              "enterprise/multi-tenancy"
            ]
          }
          
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "Using the helix CLI",
            "pages": [
              "documentation/cli-v2/getting-started",
              "documentation/cli-v2/workflows/local",
              "documentation/cli-v2/workflows/helix_cloud",
              "documentation/cli-v2/configuration",
              "documentation/cli-v2/troubleshooting"
            ]
          },
          {
            "group": "CLI Command Reference",
            "pages": [
              "documentation/cli-v2/command-reference",
              "documentation/cli-v2/command-reference/add",
              "documentation/cli-v2/command-reference/auth",
              "documentation/cli-v2/command-reference/cluster",
              "documentation/cli-v2/command-reference/dashboard",
              "documentation/cli-v2/command-reference/delete",
              "documentation/cli-v2/command-reference/feedback",
              "documentation/cli-v2/command-reference/init",
              "documentation/cli-v2/command-reference/logs",
              "documentation/cli-v2/command-reference/metrics",
              "documentation/cli-v2/command-reference/project",
              "documentation/cli-v2/command-reference/prune",
              "documentation/cli-v2/command-reference/query",
              "documentation/cli-v2/command-reference/restart",
              "documentation/cli-v2/command-reference/run",
              "documentation/cli-v2/command-reference/status",
              "documentation/cli-v2/command-reference/stop",
              "documentation/cli-v2/command-reference/sync",
              "documentation/cli-v2/command-reference/update",
              "documentation/cli-v2/command-reference/workspace"
            ]
          }
        ]
      }

    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://www.helix-db.com"
  },
  "search": {
    "prompt": "Search HelixDB Docs"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "icon": "github",
        "href": "https://github.com/HelixDB/helix-db"
      },
      {
        "label": "Discord",
        "icon": "discord",
        "href": "https://discord.com/invite/2stgMPr5BD"
      },
      {
        "label": "Support",
        "icon": "envelope",
        "href": "mailto:founders@helix-db.com"
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://www.helix-db.com",
      "github": "https://github.com/HelixDB/helix-db",
      "discord": "https://discord.com/invite/2stgMPr5BD",
      "x": "https://x.com/helixdb",
      "linkedin": "https://www.linkedin.com/company/helixdb"
    }
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "description": "HelixDB Documentation to get you started with HelixDB",
      "keywords": "HelixDB, Documentation, Getting Started, CLI, SDK, Guides, Features, Blogs, RAG, Database, Database, Graph Database, Vector Database, AI, Agents, LLMs, Knowledge Graphs, Retrieval Augmented Generation, Knowledge Graphs, AI Agents, Document databases",
      "robots": "all",
      "googlebot": "index, follow",
      "og:title": "HelixDB Docs",
      "og:description": "HelixDB Documentation",
      "og:type": "website",
      "og:site_name": "HelixDB Documentation",
      "category": "Technology",
      "language": "en",
      "author": "HelixDB"
    }
  },
  "integrations": {
    "gtm": {
      "tagId": "GTM-T8HFNXSQ"
    }
  }
}
