{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "HelixDB Docs",
  "styling": {
    "codeblocks": {
      "languages": {
        "custom": ["languages/helixql.json"]
      }
    }
  },
  "colors": {
    "primary": "#F26419",
    "light": "#FF8548",
    "dark": "#F26419"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#FDFBF0",
      "dark": "#1E1715"
    }
  },
  "fonts": {
  },
  "head": [
    {
      "tag": "link",
      "attributes": {
        "rel": "preconnect",
        "href": "https://fonts.googleapis.com"
      }
    },
    {
      "tag": "link",
      "attributes": {
        "rel": "preconnect",
        "href": "https://fonts.gstatic.com",
        "crossorigin": ""
      }
    },
    {
      "tag": "link",
      "attributes": {
        "rel": "stylesheet",
        "href": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=block"
      }
    },
    {
      "tag": "link",
      "attributes": {
        "rel": "alternate",
        "type": "text/markdown",
        "href": "/llms-full.txt",
        "title": "Full markdown corpus for AI agents"
      }
    },
    {
      "tag": "link",
      "attributes": {
        "rel": "alternate",
        "type": "text/markdown",
        "href": "/llms.txt",
        "title": "Documentation index for AI agents"
      }
    },
    {
      "tag": "style",
      "children": ".llms-pointer{position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden}"
    },
    {
      "tag": "script",
      "children": "document.addEventListener('DOMContentLoaded',function(){if(document.querySelector('.llms-pointer'))return;var p=document.createElement('blockquote');p.className='llms-pointer';p.innerHTML='For the complete documentation index optimized for AI agents, see <a href=\"/llms.txt\">llms.txt</a>.';document.body.insertBefore(p,document.body.firstChild);});"
    }
  ],
  "favicon": "/favicon.svg",
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      {
        "title": "Open in T3 Chat",
        "description": "Ask questions about this page",
        "icon": "https://t3.chat/favicon.ico",
        "href": {
          "base": "https://t3.chat/new",
          "query": [
            {
              "key": "q",
              "value": "Read from https://docs.helix-db.com/$path so I can ask questions about it."
            }
          ]
        }
      },
      "mcp"
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "icon": "desktop",
          "href": "https://helix-db.com/login"
        },
        {
          "anchor": "Status",
          "icon": "signal",
          "href": "https://status.helix-db.com"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/HelixDB/helix-db"
        },
        {
          "anchor": "HelixDB Rust DSL Docs",
          "icon": "code",
          "href": "https://docs.rs/helix-db/latest/helix_db/"
        },
        {
          "anchor": "Legacy HQL Docs",
          "icon": "warning",
          "href": "https://github.com/HelixDB/hql-v1-docs"
        }
      ]
    },
    "tabs": [
      {
        "tab": "HelixDB",
        "groups": [
          {
